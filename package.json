{
  "name": "lyric-video-maker",
  "version": "0.5.1",
  "private": true,
  "license": "SEE LICENSE IN EULA.txt",
  "author": "Kevin Gravier",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @lyric-video-maker/plugin-base build && pnpm --filter @lyric-video-maker/core --filter @lyric-video-maker/scene-registry --filter @lyric-video-maker/renderer build && pnpm --filter @lyric-video-maker/desktop build",
    "benchmark:renderer": "pnpm build && node packages/renderer/tests/render-benchmark.mjs",
    "dev": "pnpm --filter @lyric-video-maker/desktop dev",
    "setup:runtime": "node scripts/install-subtitle-sidecar.mjs && node scripts/install-chromium.mjs",
    "publish": "pnpm setup:runtime && node scripts/publish.mjs",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@puppeteer/browsers": "^2.13.0",
    "@electron/packager": "^19.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
